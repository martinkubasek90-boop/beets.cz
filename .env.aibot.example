# AIBot app <-> n8n
N8N_AIBOT_WEBHOOK_URL=https://n8n.beets.cz/webhook/aibot
N8N_AIBOT_WEBHOOK_TOKEN=CHANGE_ME

# Claude
ANTHROPIC_API_KEY=CHANGE_ME

# UI flags
AIBOT_ASSISTANT_NAME=Beets AI Assistant
AIBOT_VOICE_ENABLED=true
AIBOT_GMAIL_ENABLED=true
AIBOT_ASANA_ENABLED=true
AIBOT_GA_ENABLED=true
AIBOT_GOOGLE_ADS_ENABLED=true

# HubSpot
HUBSPOT_PRIVATE_APP_TOKEN=CHANGE_ME

# Asana
ASANA_PAT=CHANGE_ME
ASANA_WORKSPACE_GID=CHANGE_ME

# GA4
GA4_PROPERTY_ID=CHANGE_ME

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=CHANGE_ME
GOOGLE_ADS_CUSTOMER_ID=CHANGE_ME
GOOGLE_ADS_LOGIN_CUSTOMER_ID=CHANGE_ME

# Optional Google OAuth handling
# GOOGLE_CLIENT_ID=CHANGE_ME
# GOOGLE_CLIENT_SECRET=CHANGE_ME
# GOOGLE_REFRESH_TOKEN=CHANGE_ME
