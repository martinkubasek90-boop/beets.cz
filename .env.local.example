# SMTP (Forpsi)
SMTP_HOST=smtp.forpsi.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=notifications@beets.cz
SMTP_PASS=CHANGE_ME
NOTIFY_EMAIL_FROM=notifications@beets.cz

# Supabase (nutné pro dohledání e-mailu a zápis do notifications)
NEXT_PUBLIC_SUPABASE_URL=CHANGE_ME
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGE_ME
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME

# Volitelný fallback webhook (pokud nechceš SMTP)
# NOTIFY_EMAIL_WEBHOOK=
# EMAIL_WEBHOOK_URL=

# HubSpot (BESS + Memodo poptávky)
HUBSPOT_PRIVATE_APP_TOKEN=CHANGE_ME
# Volitelné globální deal nastavení
# HUBSPOT_PIPELINE=CHANGE_ME
# HUBSPOT_DEAL_STAGE=CHANGE_ME
# Volitelné Memodo-specific deal nastavení (má přednost před globálními)
# HUBSPOT_MEMODO_PIPELINE=CHANGE_ME
# HUBSPOT_MEMODO_DEAL_STAGE=CHANGE_ME
