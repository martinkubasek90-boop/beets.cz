# SMTP (Forpsi)
SMTP_HOST=smtp.forpsi.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=notifications@beets.cz
SMTP_PASS=CHANGE_ME
NOTIFY_EMAIL_FROM=notifications@beets.cz

# Supabase (nutné pro dohledání e-mailu a zápis do notifications)
NEXT_PUBLIC_SUPABASE_URL=CHANGE_ME
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGE_ME
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME

# Volitelný fallback webhook (pokud nechceš SMTP)
# NOTIFY_EMAIL_WEBHOOK=
# EMAIL_WEBHOOK_URL=

# AIBot
# Claude + integrations should run behind n8n webhook
# AIBOT_ADMIN_TOKEN=CHANGE_ME
# N8N_AIBOT_WEBHOOK_URL=https://your-n8n-host/webhook/aibot
# N8N_AIBOT_WEBHOOK_TOKEN=CHANGE_ME
# ANTHROPIC_API_KEY=CHANGE_ME
# AIBOT_ASSISTANT_NAME=Beets AI Assistant
# AIBOT_VOICE_ENABLED=true
# AIBOT_GMAIL_ENABLED=true
# AIBOT_ASANA_ENABLED=true
# AIBOT_GA_ENABLED=true
# AIBOT_GOOGLE_ADS_ENABLED=true

# HubSpot (BESS + Memodo poptávky)
HUBSPOT_PRIVATE_APP_TOKEN=CHANGE_ME
# Volitelné globální deal nastavení
# HUBSPOT_PIPELINE=CHANGE_ME
# HUBSPOT_DEAL_STAGE=CHANGE_ME
# Volitelné Memodo-specific deal nastavení (má přednost před globálními)
# HUBSPOT_MEMODO_PIPELINE=CHANGE_ME
# HUBSPOT_MEMODO_DEAL_STAGE=CHANGE_ME

# Memodo XML feed import
# MEMODO_XML_FEED_URL=https://example.com/memodo-feed.xml
# MEMODO_FEED_IMPORT_TOKEN=CHANGE_ME
# MEMODO_IMPORT_BATCH_SIZE=800
# MEMODO_IMPORT_UPSERT_CHUNK=500

# Memodo internal lead notification email
# MEMODO_SALES_EMAIL=obchod@memodo.cz

# Memodo admin protection token
# MEMODO_ADMIN_TOKEN=CHANGE_ME
